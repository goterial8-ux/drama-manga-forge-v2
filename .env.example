# Vertex AI for all planning stages and optional Gemini script writer.
GOOGLE_GENAI_USE_VERTEXAI="True"
GOOGLE_CLOUD_PROJECT="project-b05a94d2-9b34-450b-b8e"
GOOGLE_CLOUD_LOCATION="global"

# Stage models. Stage 02 macro outline and Stage 03 scene cards use Gemini 2.5 Pro.
GEMINI_FAST_MODEL="gemini-2.5-flash"
GEMINI_PRO_MODEL="gemini-2.5-pro"
GEMINI_WRITER_MODEL="gemini-3.1-pro-preview"
GEMINI_WRITER_THINKING_LEVEL="HIGH"

# Script writer switch.
# Use "tkbk" for Claude-compatible TKBK writer.
# Use "vertex_gemini" for Gemini 3.1 Pro Preview through Vertex AI.
CLAUDE_WRITER_PROVIDER="tkbk"
SCRIPT_WRITER_PROVIDER="tkbk"

# Claude-compatible final script writer through TKBK.
# Put your real key in .env.local or deployment secrets. Do not commit it.
TKBK_API_KEY=""
CLAUDE_WRITER_MODEL="claude-sonnet-4-6"
CLAUDE_WRITER_MAX_TOKENS=6500
TKBK_CLAUDE_ENDPOINT="https://api.tkbk.io/claude/v1/messages"

# Optional server port.
PORT=3000
